# Frontend build-time configuration (Vite inlines these into the bundle at build time).
# Copy to .env.production, or set in your CI / Docker build environment, before `npm run build`.

# Public HTTPS base URL of the Pulse backend (used for both REST and WebSocket).
# Must be reachable from the user's browser — do NOT leave this as localhost in production.
VITE_API_BASE_URL=https://api.your-domain.com