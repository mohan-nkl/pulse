# Copy this file to .env and fill in the values:   cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- PostgreSQL ---
DB_PASSWORD=change-me

# --- JWT (must be at least 32 characters) ---
JWT_SECRET=dev-secret-change-me-please-32chars-minimum-0123456789

# --- MinIO (object storage) ---
# These defaults match the app's defaults; change only for non-local setups.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123