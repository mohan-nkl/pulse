# Copy this file to .env and fill in the values:   cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- PostgreSQL ---
DB_PASSWORD=change-me
# In production also point at your RDS instance (append ?sslmode=require for RDS):
# DB_URL=jdbc:postgresql://your-rds-host:5432/pulse_db
# DB_USERNAME=postgres

# --- JWT (REQUIRED — at least 32 characters, no built-in default) ---
JWT_SECRET=dev-secret-change-me-please-32chars-minimum-0123456789

# --- MinIO / S3 object storage (credentials REQUIRED — no built-in defaults) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# Public, browser-reachable endpoint — presigned media URLs are built from this.
# Local default is http://localhost:9000; in production use your public S3/MinIO HTTPS URL:
# MINIO_ENDPOINT=https://storage.your-domain.com

# --- CORS / WebSocket allowed origins (comma-separated frontend URLs) ---
# Local default: http://localhost:5173,http://localhost:5174
# In production set to your deployed frontend origin(s):
# ALLOWED_ORIGINS=https://app.your-domain.com